{
  "expo": {
    "name": "upande-livestock",
    "slug": "upande-livestock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/upande_logo_no_bg.png",
    "scheme": "upandelivestock",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#FFFFFF",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/upande_logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.stivewithani.upandelivestock"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/upande_logo_no_bg.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0640a515-d7f3-4710-a550-8cf6b8934b7e"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/0640a515-d7f3-4710-a550-8cf6b8934b7e"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
